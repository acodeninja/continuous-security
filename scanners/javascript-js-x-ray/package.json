{
  "name": "@continuous-security/scanner-javascript-js-x-ray",
  "version": "1.8.1",
  "description": "Run js-x-ray against your nodejs codebase.",
  "main": "build/main.js",
  "scripts": {
    "test": "jest src/",
    "test:integration": "jest test/integration.test.ts",
    "build": "webpack",
    "lint": "eslint .",
    "prepublishOnly": "npm run update-types && npm run build",
    "update-types": "mkdir -p ./build && cp ../../application/types.scanner.d.ts ./types.d.ts && cp ./types.d.ts ./build/main.d.ts && echo \"\ndeclare const _scanner: Scanner;\nexport default _scanner;\n\" >> ./build/main.d.ts"
  },
  "keywords": [
    "security",
    "scanner",
    "@continuous-security"
  ],
  "files": [
    "build/*",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acodeninja/continuous-security.git",
    "directory": "scanners/javascript-js-x-ray"
  },
  "private": false,
  "author": "Lawrence <lawrence@acode.ninja>",
  "license": "LGPL-3.0-only",
  "devDependencies": {
    "@nodesecure/i18n": "^4.1.0",
    "@nodesecure/js-x-ray": "^6.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
