{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "es2022",
    "moduleResolution": "node",
    "outDir": "build",
    "resolveJsonModule": true,
    "target": "es2022",
    "types": ["node", "jest"]
  },
  "include": ["./src/**/*.ts", "./types.d.ts", "./types.scanner.d.ts"],
  "exclude": ["./src/**/*.test.ts"],
}
