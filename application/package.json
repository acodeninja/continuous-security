{
  "name": "@continuous-security/application",
  "version": "2.0.0",
  "description": "Command line application for running security scans against application code.",
  "scripts": {
    "test": "LANG=en_GB.utf8 TZ=UTC NODE_OPTIONS=--experimental-vm-modules jest",
    "test:long": "LANG=en_GB.utf8 TZ=UTC NODE_OPTIONS=--experimental-vm-modules WITH_FALLBACK_REPORT_RENDER=yes jest",
    "build": "npm run update-cwe && npm run update-scanner-list && webpack --config webpack.config.cjs && scripts/prepare-publish.mjs",
    "update-cwe": "scripts/update-cwe.mjs",
    "lint": "eslint ./",
    "update-scanner-types": "cd ../scanners && for d in $(ls); do [ $d != '_base' ] && cd $d && npm run update-types && cd ..; done",
    "update-scanner-list": "scripts/update-scanner-list.mjs"
  },
  "keywords": [],
  "author": "Lawrence <lawrence@acode.ninja>",
  "license": "MPL-2.0",
  "bin": {
    "continuous-security": "build/continuous-security"
  },
  "files": [
    "build/*",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "private": false,
  "devDependencies": {
    "@inquirer/checkbox": "^5.1.2",
    "@inquirer/prompts": "^8.3.2",
    "@inquirer/select": "^5.1.2",
    "@types/dockerode": "^4.0.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/npm": "^7.19.3",
    "@types/pngjs": "^6.0.5",
    "@types/tar-stream": "^3.1.4",
    "@xmldom/xmldom": "^0.8.11",
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dockerode": "^4.0.9",
    "eslint": "^10.0.3",
    "eventemitter2": "^6.4.9",
    "jest": "^30.3.0",
    "lodash": "^4.17.23",
    "minify-xml": "^4.5.2",
    "pdf-to-png-converter": "^3.14.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "showdown": "^2.1.0",
    "tar-stream": "^3.1.8",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "unzip-stream": "^0.3.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "xml-query": "^1.5.0",
    "xml-reader": "^2.4.3",
    "xpath": "^0.0.34",
    "yaml": "^2.8.2"
  }
}
